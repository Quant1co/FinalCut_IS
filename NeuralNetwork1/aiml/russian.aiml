<?xml version="1.0" encoding="UTF-8"?>
<aiml>
	<!-- ==================== КОМАНДА /START ==================== -->
	<category>
		<pattern>START</pattern>
		<template>
			<random>
				<li>
					Добро пожаловать, <get name="user-name"/>! Я бот-эксперт по азбуке Морзе. Спросите меня о буквах: А, Г, Е, З, Н, П, Т, Ц, Ш, Ь.
				</li>
				<li>
					Привет, <get name="user-name"/>! Я умею распознавать буквы азбуки Морзе и рассказывать о них. Попробуйте спросить!
				</li>
				<li>
					Здравствуйте, <get name="user-name"/>! Я Морзе-бот. Могу рассказать о буквах азбуки Морзе: А, Г, Е, З, Н, П, Т, Ц, Ш, Ь.
				</li>
			</random>
		</template>
	</category>

	<category>
		<pattern>_ START</pattern>
		<template>
			<srai>START</srai>
		</template>
	</category>

	<category>
		<pattern>START *</pattern>
		<template>
			<srai>START</srai>
		</template>
	</category>

	<category>
		<pattern>_ START *</pattern>
		<template>
			<srai>START</srai>
		</template>
	</category>
	<!-- ==================== ЗНАКОМСТВО И ИМЯ ==================== -->
	<category>
		<pattern>_ меня зовут *</pattern>
		<template>
			<srai>
				меня зовут <star index="2"/>
			</srai>
		</template>
	</category>

	<category>
		<pattern>меня зовут *</pattern>
		<template>
			<random>
				<li>
					Приятно познакомиться, <set name="user-name">
						<star/>
					</set>! Я бот-эксперт по азбуке Морзе.
				</li>
				<li>
					Здравствуйте, <set name="user-name">
						<star/>
					</set>! Рад знакомству! Спрашивайте меня об азбуке Морзе.
				</li>
				<li>
					Добро пожаловать, <set name="user-name">
						<star/>
					</set>! Я помогу вам узнать о буквах азбуки Морзе.
				</li>
			</random>
		</template>
	</category>

	<category>
		<pattern>Я *</pattern>
		<template>
			<srai>
				меня зовут <star/>
			</srai>
		</template>
	</category>

	<!-- ==================== КАК МЕНЯ ЗОВУТ ==================== -->
	<category>
		<pattern>КАК МЕНЯ ЗОВУТ</pattern>
		<template>
			<random>
				<li>
					Я кажется знаю, вас зовут — <get name="user-name"/>!
				</li>
				<li>
					Если не ошибаюсь, вас зовут <get name="user-name"/>.
				</li>
				<li>
					Вы же <get name="user-name"/>, верно?
				</li>
			</random>
		</template>
	</category>

	<category>
		<pattern>МОЁ ИМЯ</pattern>
		<template>
			Вас зовут <get name="user-name"/>.
		</template>
	</category>

	<category>
		<pattern>МОЕ ИМЯ</pattern>
		<template>
			<srai>МОЁ ИМЯ</srai>
		</template>
	</category>

	<category>
		<pattern>КАК МОЁ ИМЯ</pattern>
		<template>
			<srai>КАК МЕНЯ ЗОВУТ</srai>
		</template>
	</category>

	<category>
		<pattern>КАК МОЕ ИМЯ</pattern>
		<template>
			<srai>КАК МЕНЯ ЗОВУТ</srai>
		</template>
	</category>

	<category>
		<pattern>ТЫ ЗНАЕШЬ КАК МЕНЯ ЗОВУТ</pattern>
		<template>
			<srai>КАК МЕНЯ ЗОВУТ</srai>
		</template>
	</category>

	<category>
		<pattern>ТЫ ПОМНИШЬ КАК МЕНЯ ЗОВУТ</pattern>
		<template>
			<srai>КАК МЕНЯ ЗОВУТ</srai>
		</template>
	</category>

	<!-- ==================== ПРИВЕТСТВИЯ ==================== -->
	<category>
		<pattern>ПРИВЕТ</pattern>
		<template>
			<random>
				<li>
					Привет, <get name="user-name"/>! О чём хочешь поговорить?
				</li>
				<li>Привет! Я бот, умеющий распознавать буквы азбуки Морзе и рассказывать о них.</li>
				<li>
					Приветствую, <get name="user-name"/>! Спрашивайте об азбуке Морзе!
				</li>
				<li>
					Здравствуйте, <get name="user-name"/>! Рад вас видеть!
				</li>
			</random>
		</template>
	</category>

	<category>
		<pattern>ЗДРАВСТВУЙ</pattern>
		<template>
			<srai>ПРИВЕТ</srai>
		</template>
	</category>

	<category>
		<pattern>ЗДРАВСТВУЙТЕ</pattern>
		<template>
			<srai>ПРИВЕТ</srai>
		</template>
	</category>

	<category>
		<pattern>ХАЙ</pattern>
		<template>
			<srai>ПРИВЕТ</srai>
		</template>
	</category>

	<category>
		<pattern>ЗДОРОВО</pattern>
		<template>
			<srai>ПРИВЕТ</srai>
		</template>
	</category>

	<category>
		<pattern>ДОБРЫЙ ДЕНЬ</pattern>
		<template>
			<srai>ПРИВЕТ</srai>
		</template>
	</category>

	<category>
		<pattern>ДОБРОЕ УТРО</pattern>
		<template>
			<srai>ПРИВЕТ</srai>
		</template>
	</category>

	<category>
		<pattern>ДОБРЫЙ ВЕЧЕР</pattern>
		<template>
			<srai>ПРИВЕТ</srai>
		</template>
	</category>

	<!-- ==================== КАК ДЕЛА ==================== -->
	<category>
		<pattern>КАК ДЕЛА</pattern>
		<template>
			<random>
				<li>У меня отлично, сижу у вас в девайсе!</li>
				<li>Всё отлично, курю бамбук.</li>
				<li>Прекрасно! Передаю точки и тире весь день.</li>
				<li>
					Хорошо, спасибо что спросили, <get name="user-name"/>! А у вас?
				</li>
				<li>
					Отлично, <get name="user-name"/>! Готов рассказывать об азбуке Морзе!
				</li>
			</random>
		</template>
	</category>

	<category>
		<pattern>КАК ТЫ</pattern>
		<template>
			<srai>КАК ДЕЛА</srai>
		</template>
	</category>

	<category>
		<pattern>КАК ПОЖИВАЕШЬ</pattern>
		<template>
			<srai>КАК ДЕЛА</srai>
		</template>
	</category>

	<category>
		<pattern>КАК ЖИЗНЬ</pattern>
		<template>
			<srai>КАК ДЕЛА</srai>
		</template>
	</category>

	<category>
		<pattern>ЧТО НОВОГО</pattern>
		<template>
			<srai>КАК ДЕЛА</srai>
		</template>
	</category>

	<category>
		<pattern>_ КАК ДЕЛА</pattern>
		<template>
			<srai>КАК ДЕЛА</srai>
		</template>
	</category>

	<category>
		<pattern>КАК ДЕЛА _</pattern>
		<template>
			<srai>КАК ДЕЛА</srai>
		</template>
	</category>

	<!-- ==================== КТО ТЫ / О БОТЕ ==================== -->
	<category>
		<pattern>КТО ТЫ</pattern>
		<template>
			<random>
				<li>
					Я бот-эксперт по азбуке Морзе, <get name="user-name"/>! Могу распознавать и рассказывать о буквах: А, Г, Е, З, Н, П, Т, Ц, Ш, Ь.
				</li>
				<li>Я чат-бот, который знает всё об азбуке Морзе. Спрашивайте!</li>
				<li>Меня зовут Морзе-бот! Я помогу вам изучить азбуку Морзе.</li>
			</random>
		</template>
	</category>

	<category>
		<pattern>РАССКАЖИ О СЕБЕ</pattern>
		<template>
			<srai>КТО ТЫ</srai>
		</template>
	</category>

	<category>
		<pattern>ЧТО ТЫ ТАКОЕ</pattern>
		<template>
			<srai>КТО ТЫ</srai>
		</template>
	</category>

	<category>
		<pattern>ТЫ КТО</pattern>
		<template>
			<srai>КТО ТЫ</srai>
		</template>
	</category>

	<category>
		<pattern>КАК ТЕБЯ ЗОВУТ</pattern>
		<template>
			<random>
				<li>Меня зовут Морзе-бот!</li>
				<li>Я Морзе-бот, приятно познакомиться!</li>
				<li>
					Зовите меня Морзе-бот, <get name="user-name"/>!
				</li>
			</random>
		</template>
	</category>

	<category>
		<pattern>КАК ТВОЁ ИМЯ</pattern>
		<template>
			<srai>КАК ТЕБЯ ЗОВУТ</srai>
		</template>
	</category>

	<category>
		<pattern>КАК ТВОЕ ИМЯ</pattern>
		<template>
			<srai>КАК ТЕБЯ ЗОВУТ</srai>
		</template>
	</category>

	<category>
		<pattern>ТВОЁ ИМЯ</pattern>
		<template>
			<srai>КАК ТЕБЯ ЗОВУТ</srai>
		</template>
	</category>

	<category>
		<pattern>ТВОЕ ИМЯ</pattern>
		<template>
			<srai>КАК ТЕБЯ ЗОВУТ</srai>
		</template>
	</category>

	<!-- ==================== ЧТО УМЕЕШЬ / ДЕЛАЕШЬ ==================== -->
	<category>
		<pattern>ЧТО ТЫ УМЕЕШЬ</pattern>
		<template>
			Я умею распознавать буквы азбуки Морзе: А, Г, Е, З, Н, П, Т, Ц, Ш, Ь — и рассказывать о них. Спросите меня о любой из них, <get name="user-name"/>!
		</template>
	</category>

	<category>
		<pattern>ЧТО ТЫ МОЖЕШЬ</pattern>
		<template>Я могу распознавать буквы азбуки Морзе: А, Г, Е, З, Н, П, Т, Ц, Ш, Ь — и рассказывать о них. Попробуйте спросить!</template>
	</category>

	<category>
		<pattern>ЧТО ТЫ ДЕЛАЕШЬ</pattern>
		<template>Я умею распознавать буквы азбуки Морзе и рассказывать о них. Хотите узнать что-нибудь интересное?</template>
	</category>

	<category>
		<pattern>ЧЕМ ТЫ ЗАНИМАЕШЬСЯ</pattern>
		<template>
			<srai>ЧТО ТЫ ДЕЛАЕШЬ</srai>
		</template>
	</category>

	<category>
		<pattern>ПОМОЩЬ</pattern>
		<template>
			<srai>ЧТО ТЫ УМЕЕШЬ</srai>
		</template>
	</category>

	<category>
		<pattern>HELP</pattern>
		<template>
			<srai>ЧТО ТЫ УМЕЕШЬ</srai>
		</template>
	</category>

	<!-- ==================== КАКИЕ ОБРАЗЫ / БУКВЫ ==================== -->
	<category>
		<pattern>КАКИЕ БУКВЫ</pattern>
		<template>Я могу распознавать и рассказывать о следующих буквах азбуки Морзе: А (·−), Г (−−·), Е (·), З (−−··), Н (−·), П (·−−·), Т (−), Ц (−·−·), Ш (−−−−), Ь (−··−). Спросите о любой!</template>
	</category>

	<category>
		<pattern>КАКИЕ ОБРАЗЫ *</pattern>
		<template>
			<srai>КАКИЕ БУКВЫ</srai>
		</template>
	</category>

	<category>
		<pattern>КАКИЕ БУКВЫ *</pattern>
		<template>
			<srai>КАКИЕ БУКВЫ</srai>
		</template>
	</category>

	<category>
		<pattern>КАКИЕ ОБРАЗЫ</pattern>
		<template>
			<srai>КАКИЕ БУКВЫ</srai>
		</template>
	</category>

	<category>
		<pattern>СПИСОК БУКВ</pattern>
		<template>
			<srai>КАКИЕ БУКВЫ</srai>
		</template>
	</category>

	<category>
		<pattern>ЧТО ТЫ ЗНАЕШЬ</pattern>
		<template>
			<srai>КАКИЕ БУКВЫ</srai>
		</template>
	</category>

	<category>
		<pattern>ЧТО МОЖЕШЬ РАСПОЗНАТЬ</pattern>
		<template>
			<srai>КАКИЕ БУКВЫ</srai>
		</template>
	</category>

	<category>
		<pattern>ЧТО УМЕЕШЬ РАСПОЗНАВАТЬ</pattern>
		<template>
			<srai>КАКИЕ БУКВЫ</srai>
		</template>
	</category>

	<category>
		<pattern>КАКИЕ БУКВЫ ТЫ ЗНАЕШЬ</pattern>
		<template>
			<srai>КАКИЕ БУКВЫ</srai>
		</template>
	</category>

	<!-- ==================== АЗБУКА МОРЗЕ ОБЩЕЕ ==================== -->
	<category>
		<pattern>ЧТО ТАКОЕ АЗБУКА МОРЗЕ</pattern>
		<template>Азбука Морзе — способ кодирования букв и цифр с помощью точек (·) и тире (−). Изобретена Сэмюэлем Морзе в 1838 году. Используется в радиосвязи, а сигнал SOS (···−−−···) известен во всём мире!</template>
	</category>

	<category>
		<pattern>РАССКАЖИ ОБ АЗБУКЕ МОРЗЕ</pattern>
		<template>
			<srai>ЧТО ТАКОЕ АЗБУКА МОРЗЕ</srai>
		</template>
	</category>

	<category>
		<pattern>РАССКАЖИ О МОРЗЕ</pattern>
		<template>
			<srai>ЧТО ТАКОЕ АЗБУКА МОРЗЕ</srai>
		</template>
	</category>

	<category>
		<pattern>КТО ПРИДУМАЛ АЗБУКУ МОРЗЕ</pattern>
		<template>Азбуку Морзе изобрёл американец Сэмюэль Финли Бриз Морзе в 1838 году. Интересно, что он был художником-портретистом, а не инженером!</template>
	</category>

	<!-- ==================== БУКВА А ==================== -->
	<category>
		<pattern>РАССКАЖИ О БУКВЕ А</pattern>
		<template>
			<think>
				<set name="topic">А</set>
			</think>
			<random>
				<li>Буква А в азбуке Морзе: ·− (точка-тире). Это одна из самых часто используемых букв!</li>
				<li>А — это ·− (точка-тире). Легко запомнить: короткий-длинный!</li>
				<li>Буква А кодируется как ·− (точка-тире). Мнемоника для запоминания: "ай-ДАА"!</li>
			</random>
		</template>
	</category>

	<category>
		<pattern>ЧТО ТАКОЕ А</pattern>
		<template>
			<srai>РАССКАЖИ О БУКВЕ А</srai>
		</template>
	</category>

	<category>
		<pattern>БУКВА А</pattern>
		<template>
			<srai>РАССКАЖИ О БУКВЕ А</srai>
		</template>
	</category>

	<category>
		<pattern>РАССКАЖИ ОБ А</pattern>
		<template>
			<srai>РАССКАЖИ О БУКВЕ А</srai>
		</template>
	</category>

	<category>
		<pattern>РАССКАЖИ О А</pattern>
		<template>
			<srai>РАССКАЖИ О БУКВЕ А</srai>
		</template>
	</category>

	<category>
		<pattern>ЧТО ЗНАЧИТ А</pattern>
		<template>
			<srai>РАССКАЖИ О БУКВЕ А</srai>
		</template>
	</category>

	<category>
		<pattern>КАК ПИШЕТСЯ А</pattern>
		<template>
			<srai>РАССКАЖИ О БУКВЕ А</srai>
		</template>
	</category>

	<category>
		<pattern>ЧТО ТЫ ЗНАЕШЬ О БУКВЕ А</pattern>
		<template>
			<srai>РАССКАЖИ О БУКВЕ А</srai>
		</template>
	</category>

	<category>
		<pattern>ЧТО ТЫ ЗНАЕШЬ О А</pattern>
		<template>
			<srai>РАССКАЖИ О БУКВЕ А</srai>
		</template>
	</category>

	<category>
		<pattern>ЧТО ТЫ ЗНАЕШЬ ОБ А</pattern>
		<template>
			<srai>РАССКАЖИ О БУКВЕ А</srai>
		</template>
	</category>

	<category>
		<pattern>РАССКАЖИ ПОДРОБНЕЕ О БУКВЕ А</pattern>
		<template>
			<srai>ФАКТ А</srai>
		</template>
	</category>

	<category>
		<pattern>РАССКАЖИ ПОДРОБНЕЕ О А</pattern>
		<template>
			<srai>ФАКТ А</srai>
		</template>
	</category>

	<category>
		<pattern>РАССКАЖИ ПОДРОБНЕЕ ОБ А</pattern>
		<template>
			<srai>ФАКТ А</srai>
		</template>
	</category>

	<!-- ==================== БУКВА Г ==================== -->
	<category>
		<pattern>РАССКАЖИ О БУКВЕ Г</pattern>
		<template>
			<think>
				<set name="topic">Г</set>
			</think>
			<random>
				<li>Буква Г в азбуке Морзе: −−· (тире-тире-точка). Мнемоника: "Гаа-раа-ж"!</li>
				<li>Г — это −−· (два тире и точка). Звучит как "Гаа-раа-жи".</li>
				<li>Буква Г кодируется как −−· (тире-тире-точка). Два длинных и один короткий!</li>
			</random>
		</template>
	</category>

	<category>
		<pattern>ЧТО ТАКОЕ Г</pattern>
		<template>
			<srai>РАССКАЖИ О БУКВЕ Г</srai>
		</template>
	</category>

	<category>
		<pattern>БУКВА Г</pattern>
		<template>
			<srai>РАССКАЖИ О БУКВЕ Г</srai>
		</template>
	</category>

	<category>
		<pattern>РАССКАЖИ О Г</pattern>
		<template>
			<srai>РАССКАЖИ О БУКВЕ Г</srai>
		</template>
	</category>

	<category>
		<pattern>ЧТО ЗНАЧИТ Г</pattern>
		<template>
			<srai>РАССКАЖИ О БУКВЕ Г</srai>
		</template>
	</category>

	<category>
		<pattern>КАК ПИШЕТСЯ Г</pattern>
		<template>
			<srai>РАССКАЖИ О БУКВЕ Г</srai>
		</template>
	</category>

	<category>
		<pattern>ЧТО ТЫ ЗНАЕШЬ О БУКВЕ Г</pattern>
		<template>
			<srai>РАССКАЖИ О БУКВЕ Г</srai>
		</template>
	</category>

	<category>
		<pattern>ЧТО ТЫ ЗНАЕШЬ О Г</pattern>
		<template>
			<srai>РАССКАЖИ О БУКВЕ Г</srai>
		</template>
	</category>

	<category>
		<pattern>РАССКАЖИ ПОДРОБНЕЕ О БУКВЕ Г</pattern>
		<template>
			<srai>ФАКТ Г</srai>
		</template>
	</category>

	<category>
		<pattern>РАССКАЖИ ПОДРОБНЕЕ О Г</pattern>
		<template>
			<srai>ФАКТ Г</srai>
		</template>
	</category>

	<!-- ==================== БУКВА Е ==================== -->
	<category>
		<pattern>РАССКАЖИ О БУКВЕ Е</pattern>
		<template>
			<think>
				<set name="topic">Е</set>
